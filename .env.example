# =============================================================
# Oz Services - Florida Taxi | Environment Variables Example
# =============================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to GitHub

# ─── Public Site Config ──────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_GOOGLE_ANALYTICS=G-XXXXXXXXXX
NEXT_PUBLIC_WHATSAPP=+1XXXXXXXXXX
NEXT_PUBLIC_PHONE=+1XXXXXXXXXX

# ─── Admin Credentials ───────────────────────────────────────
# These seed the first admin user in the database on startup
ADMIN_EMAIL=your-admin@email.com
ADMIN_PASSWORD=your-secure-password
ADMIN_NAME=Your Name

# ─── JWT Secret ──────────────────────────────────────────────
# Generate a strong random string for production
JWT_SECRET=your-super-secret-jwt-key-here

# ─── Email (Resend) ───────────────────────────────────────────
# Sign up free at https://resend.com
# Free tier: 3,000 emails/month, no credit card required
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender email (must be verified domain in Resend dashboard)
# For testing, use: onboarding@resend.dev (Resend default)
FROM_EMAIL=noreply@your-domain.com

# Admin email to receive booking notifications
ADMIN_EMAIL_NOTIFY=your-admin@email.com

# ─── Vercel Cron Secret ───────────────────────────────────────
# Set this in Vercel dashboard too — used to authenticate cron calls
CRON_SECRET=your-cron-secret-key-here
